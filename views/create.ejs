<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Article</title>
  <link rel="stylesheet" href="style.css">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <span class="header-tag">New</span>
      <h1>Create Article</h1>
    </div>

    <div class="card">
      <form action="/" method="post">
        <div class="field">
          <label for="title">Title <span class="req">*</span></label>
          <input type="text" id="title" name="title" placeholder="Enter article title…" required>
        </div>

        <div class="field">
          <label for="summary">Summary <span class="req">*</span></label>
          <input type="text" id="summary" name="summary" placeholder="One-line description…" required>
        </div>

        <div class="field">
          <label for="body">Body <span class="req">*</span></label>
          <textarea id="body" name="body" placeholder="Write your article content here…" required></textarea>
        </div>

        <hr class="divider">
        <div class="footer-row">
          <span class="footer-note">All fields required</span>
          <button type="submit" class="create">Publish →</button>
        </div>

      </form>
    </div>
  </div>
</body>
</html>